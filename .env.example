# Doubao API Configuration (ByteDance Volces Ark)
# DOUBAO_API_KEY is your API key from Volces console
# In Volces Ark, the endpoint ID is passed as the "model" parameter
DOUBAO_API_KEY=your-api-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Endpoint ID for chat/prompt enhancement (doubao-seed-2.0-pro)
DOUBAO_CHAT_MODEL=ark-xxxxxxxx-xxxx-xxxx-xxxxxxxxxxxx-xxxxx
# Endpoint ID for text-to-image generation (doubao-seedream-5-0-260128)
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128

# Output Configuration
OUTPUT_DIR=./outputs

# Image generation size (configurable)
# API requires at least ~3.68 million pixels (3686400)
# Common valid options:
# - 1920x1080 (2073600 pixels - no, actually 1920*1080=2073600 still too small)
# - 1920x1920 (3686400 pixels) meets the requirement
# - 1440x2560 (3686400 pixels) vertical
# - 2048x1792 (3670016 pixels) close enough
DEFAULT_IMAGE_WIDTH=1920
DEFAULT_IMAGE_HEIGHT=1920

# Text Rendering Defaults
DEFAULT_FONT_SIZE=48
DEFAULT_TEXT_COLOR=#ffffff
DEFAULT_STROKE_COLOR=#000000
DEFAULT_STROKE_WIDTH=3
DEFAULT_PADDING=40
DEFAULT_GRADIENT_OPACITY=0.4
DEFAULT_TEXT_POSITION=bottom  # bottom, top, center, auto (auto = smart selection)
